---
import { Icon } from "astro-icon/components";

interface Site {
	name: string;
	url: string;
}

const sites: Site[] = [
	{ name: "CC 的个人知识库", url: "https://cn3.top/" },
	{ name: "CC 的个人知识库", url: "https://blog.cn3.top/" },
];
---

<div class="card-base rounded-[var(--radius-large)] px-6 py-5">
	<div class="flex items-center justify-between mb-3">
		<h2 class="text-lg font-bold">镜像站点</h2>
		<button id="ping-all" class="btn-regular h-8 px-3 rounded-lg text-xs flex items-center gap-1">
			<Icon name="material-symbols:refresh-rounded" class="text-[1rem]" />
			全部重测
		</button>
	</div>
	<div class="flex flex-col gap-2" id="site-list">
		{sites.map((site) => (
			<div class="flex items-center justify-between bg-[var(--page-bg)] rounded-lg px-4 py-3" data-ping-url={site.url}>
				<a href={site.url} target="_blank" class="font-medium text-sm hover:text-[var(--primary)] transition shrink-0 mr-4">
					{site.name}
				</a>
				<span class="ping-result text-xs text-[var(--text-secondary)] shrink-0">检测中...</span>
			</div>
		))}
	</div>
</div>

<script>
async function ping(url) {
	const start = performance.now();
	try {
		// 先尝试常规 fetch
		await fetch(url, { method: "HEAD", cache: "no-store" });
	} catch {
		// 跨域则用 no-cors（只能测时间，无法得知 HTTP 状态）
		try {
			await fetch(url, { method: "HEAD", mode: "no-cors", cache: "no-store" });
		} catch {
			return null;
		}
	}
	return Math.round(performance.now() - start);
}

async function updatePing(el) {
	const url = el.dataset.pingUrl!;
	const result = el.querySelector(".ping-result")!;
	const startTime = Date.now();

	result.textContent = "检测中...";

	const ms = await ping(url);

	// 至少显示 300ms 防止闪烁
	const elapsed = Date.now() - startTime;
	if (elapsed < 300) {
		await new Promise((r) => setTimeout(r, 300 - elapsed));
	}

	if (ms === null) {
		result.textContent = "超时";
		return;
	}

	let color = "text-green-500";
	if (ms > 200) color = "text-yellow-500";
	if (ms > 500) color = "text-red-500";

	result.textContent = `${ms} ms`;
	result.className = `ping-result text-xs font-medium shrink-0 ${color}`;
}

function init() {
	document.querySelectorAll<HTMLElement>("[data-ping-url]").forEach(updatePing);

	document.getElementById("ping-all")?.addEventListener("click", () => {
		document.querySelectorAll<HTMLElement>("[data-ping-url]").forEach(updatePing);
	});
}

if (document.readyState === "loading") {
	document.addEventListener("DOMContentLoaded", init);
} else {
	init();
}
</script>
