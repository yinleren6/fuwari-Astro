---
import { Icon } from "astro-icon/components";

import { siteConfig } from "../../config";
import {
	getCategoryList,
	getSortedPosts,
	getTagList,
} from "../../utils/content-utils";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";

interface Props {
	class?: string;
	style?: string;
}

const { class: className, style } = Astro.props;

const siteStartDate = siteConfig.siteStartDate || "2025-01-01";

const posts = await getSortedPosts();
const categories = await getCategoryList();
const tags = await getTagList();

// word count
let totalWords = 0;
for (const post of posts) {
	if (post.body) {
		let text = post.body;
		text = text.replace(/```[\s\S]*?```/g, "");
		text = text.replace(/`[^`]+`/g, "");
		const cjkPattern = /[一-龥぀-ゟ゠-ヿ가-힯　-〿＀-￯]/g;
		const cjkMatches = text.match(cjkPattern);
		const cjkCount = cjkMatches ? cjkMatches.length : 0;
		const nonCjkText = text.replace(cjkPattern, " ");
		const nonCjkWords = nonCjkText
			.split(/\s+/)
			.filter((word) => word.trim().length > 0);
		totalWords += cjkCount + nonCjkWords.length;
	}
}

function formatNumber(num: number): string {
	return num.toLocaleString();
}

const latestPost = posts.reduce((latest, post) => {
	if (!latest) return post;
	return post.data.published > latest.data.published ? post : latest;
}, posts[0]);

const lastPostDate = latestPost
	? latestPost.data.published.toISOString()
	: null;
---

<div class="card-base pb-4">
	<div class="font-bold transition text-lg text-neutral-900 dark:text-neutral-100 relative ml-8 mt-4 mb-2
		before:w-1 before:h-4 before:rounded-md before:bg-[var(--primary)]
		before:absolute before:left-[-16px] before:top-[5.5px]">{i18n(I18nKey.siteStats)}</div>
	<div id="site-stats" class="px-4">
	<div class="flex flex-col gap-1">
		<div class="flex items-center justify-between px-2 py-2">
			<div class="flex items-center gap-2.5 flex-1 min-w-0">
				<div class="text-[var(--primary)] text-xl shrink-0">
					<Icon name="material-symbols:article-outline" />
				</div>
				<span class="text-neutral-700 dark:text-neutral-300 font-medium text-sm break-words leading-tight">
					{i18n(I18nKey.siteStatsPostCount)}
				</span>
			</div>
			<span class="text-base font-bold text-neutral-900 dark:text-neutral-100 shrink-0 ml-3">
				{posts.length}
			</span>
		</div>
		<div class="flex items-center justify-between px-2 py-2">
			<div class="flex items-center gap-2.5 flex-1 min-w-0">
				<div class="text-[var(--primary)] text-xl shrink-0">
					<Icon name="material-symbols:folder-outline" />
				</div>
				<span class="text-neutral-700 dark:text-neutral-300 font-medium text-sm break-words leading-tight">
					{i18n(I18nKey.siteStatsCategoryCount)}
				</span>
			</div>
			<span class="text-base font-bold text-neutral-900 dark:text-neutral-100 shrink-0 ml-3">
				{categories.length}
			</span>
		</div>
		<div class="flex items-center justify-between px-2 py-2">
			<div class="flex items-center gap-2.5 flex-1 min-w-0">
				<div class="text-[var(--primary)] text-xl shrink-0">
					<Icon name="material-symbols:label-outline" />
				</div>
				<span class="text-neutral-700 dark:text-neutral-300 font-medium text-sm break-words leading-tight">
					{i18n(I18nKey.siteStatsTagCount)}
				</span>
			</div>
			<span class="text-base font-bold text-neutral-900 dark:text-neutral-100 shrink-0 ml-3">
				{tags.length}
			</span>
		</div>
		<div class="flex items-center justify-between px-2 py-2">
			<div class="flex items-center gap-2.5 flex-1 min-w-0">
				<div class="text-[var(--primary)] text-xl shrink-0">
					<Icon name="material-symbols:text-ad-outline-rounded" />
				</div>
				<span class="text-neutral-700 dark:text-neutral-300 font-medium text-sm break-words leading-tight">
					{i18n(I18nKey.siteStatsTotalWords)}
				</span>
			</div>
			<span class="text-base font-bold text-neutral-900 dark:text-neutral-100 shrink-0 ml-3">
				{formatNumber(totalWords)}
			</span>
		</div>
		<div class="flex items-center justify-between px-2 py-2">
			<div class="flex items-center gap-2.5 flex-1 min-w-0">
				<div class="text-[var(--primary)] text-xl shrink-0">
					<Icon name="material-symbols:visibility-outline" />
				</div>
				<span class="text-neutral-700 dark:text-neutral-300 font-medium text-sm break-words leading-tight">
					{i18n(I18nKey.siteStatsPageViews)}
				</span>
			</div>
			<span class="text-base font-bold text-neutral-900 dark:text-neutral-100 shrink-0 ml-3" id="stats-total-pv">
				--
			</span>
		</div>
		<div class="flex items-center justify-between px-2 py-2">
			<div class="flex items-center gap-2.5 flex-1 min-w-0">
				<div class="text-[var(--primary)] text-xl shrink-0">
					<Icon name="material-symbols:calendar-clock-outline" />
				</div>
				<span class="text-neutral-700 dark:text-neutral-300 font-medium text-sm break-words leading-tight">
					{i18n(I18nKey.siteStatsRunningDays)}
				</span>
			</div>
			<div class="flex items-center ml-3 shrink-0">
				<span class="text-base font-bold text-neutral-900 dark:text-neutral-100" id="stats-running-days">0</span>
				<span class="text-sm text-neutral-500 dark:text-neutral-400 ml-1">{i18n(I18nKey.siteStatsDays)}</span>
			</div>
		</div>
		<div class="flex items-center justify-between px-2 py-2">
			<div class="flex items-center gap-2.5 flex-1 min-w-0">
				<div class="text-[var(--primary)] text-xl shrink-0">
					<Icon name="material-symbols:ecg-heart-outline" />
				</div>
				<span class="text-neutral-700 dark:text-neutral-300 font-medium text-sm break-words leading-tight">
					{i18n(I18nKey.siteStatsLastUpdate)}
				</span>
			</div>
			<div class="flex items-center ml-3 shrink-0">
				<span class="text-base font-bold text-neutral-900 dark:text-neutral-100" id="stats-last-update">0</span>
				<span class="text-sm text-neutral-500 dark:text-neutral-400 ml-1" id="stats-last-update-unit">前</span>
			</div>
		</div>
	</div>
</div>  <!-- px-4 -->
</div>  <!-- card-base -->

<script is:inline define:vars={{ siteStartDate, lastPostDate }}>
	async function fetchPageViews() {
		try {
			const res = await fetch("/api/view");
			if (res.ok) {
				const data = await res.json();
				const el = document.getElementById("stats-total-pv");
				if (el) el.textContent = data.total.toLocaleString();
			}
		} catch {}
	}

	function updateDynamicStats() {
		const today = new Date();

		// running days
		const startDate = new Date(siteStartDate);
		const diffTime = Math.abs(today.getTime() - startDate.getTime());
		const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
		const runningEl = document.getElementById("stats-running-days");
		if (runningEl) runningEl.textContent = diffDays.toString();

		// last update
		if (lastPostDate) {
			const lastPost = new Date(lastPostDate);
			const ms = Math.abs(today.getTime() - lastPost.getTime());
			const mins = Math.floor(ms / 60000);
			const hours = Math.floor(ms / 3600000);
			const days = Math.floor(ms / 86400000);
			let val, unit;
			if (days >= 1) { val = days; unit = "天前"; }
			else if (hours >= 1) { val = hours; unit = "小时前"; }
			else { val = Math.max(mins, 1); unit = "分钟前"; }
			const el = document.getElementById("stats-last-update");
			const unitEl = document.getElementById("stats-last-update-unit");
			if (el) el.textContent = val.toString();
			if (unitEl) unitEl.textContent = unit;
		}
	}

	fetchPageViews();
	updateDynamicStats();
	setInterval(updateDynamicStats, 60 * 60 * 1000);
</script>
