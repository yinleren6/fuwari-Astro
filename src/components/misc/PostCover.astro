---
import ImageWrapper from "./ImageWrapper.astro";

interface Props {
	image?: string;
	title: string;
	category?: string | null;
	basePath?: string;
	class?: string;
	id?: string;
}

const { image, title, category, basePath, class: className, id } = Astro.props;
const hasImage = image && image !== "";
const cat = category || "";

const safeTitle = title
	.replace(/&/g, "&amp;")
	.replace(/</g, "&lt;")
	.replace(/>/g, "&gt;")
	.replace(/"/g, "&quot;");

// Deterministic pseudo-random for shapes only
let rng = (() => {
	let h = 0;
	const s = title || "default";
	for (let i = 0; i < s.length; i++) h = ((h << 5) - h + s.charCodeAt(i)) | 0;
	return Math.abs(h) || 1;
})();

function rnd(min: number, max: number): number {
	rng = (rng * 16807) % 2147483647;
	return min + (rng / 2147483647) * (max - min);
}
function ri(min: number, max: number): number {
	return Math.round(rnd(min, max));
}
function pick<T>(arr: T[]): T {
	return arr[ri(0, arr.length - 1)];
}

// Build shapes (white only, varying opacity)
let shapesHtml = "";
for (let i = 0, n = ri(5, 9); i < n; i++) {
	const cx = rnd(-20, 220).toFixed(0);
	const cy = rnd(-20, 280).toFixed(0);
	const sz = rnd(30, 140);
	const op = rnd(0.03, 0.1).toFixed(3);
	const rot = rnd(0, 360).toFixed(0);
	const type = pick(["circle", "blob", "rect", "tri", "diamond"]);
	const half = (sz / 2).toFixed(0);

	if (type === "circle") {
		shapesHtml += `<circle cx="${cx}" cy="${cy}" r="${half}" fill="white" opacity="${op}"/>`;
	} else if (type === "rect") {
		const rh = (sz * 0.6).toFixed(0);
		const rx = (sz * 0.15).toFixed(0);
		shapesHtml += `<rect x="${cx}" y="${cy}" width="${sz.toFixed(0)}" height="${rh}" rx="${rx}" fill="white" opacity="${op}" transform="rotate(${rot},${cx},${cy})"/>`;
	} else if (type === "tri") {
		const h3 = (sz * 0.433).toFixed(0);
		shapesHtml += `<polygon points="${cx},${+cx - +h3 / 2} ${+cx - +half},${+cy + +h3 / 2} ${+cx + +half},${+cy + +h3 / 2}" fill="white" opacity="${op}" transform="rotate(${rot},${cx},${cy})"/>`;
	} else if (type === "diamond") {
		shapesHtml += `<polygon points="${cx},${+cy - +half} ${+cx + +half},${cy} ${cx},${+cy + +half} ${+cx - +half},${cy}" fill="white" opacity="${op}" transform="rotate(${rot},${cx},${cy})"/>`;
	} else {
		const rx = (sz * 0.4).toFixed(0);
		shapesHtml += `<rect x="${cx}" y="${cy}" width="${sz.toFixed(0)}" height="${sz.toFixed(0)}" rx="${rx}" fill="white" opacity="${op}" transform="rotate(${rot},${cx},${cy})"/>`;
	}
	shapesHtml += "\n        ";
}

const dotSize = rnd(1, 3).toFixed(1);
const titleHtml = `<div style="color:white;font-size:16px;font-weight:700;font-family:system-ui,sans-serif;line-height:1.3;text-align:center;word-wrap:break-word;overflow-wrap:break-word;max-height:100%;overflow:hidden;display:-webkit-box;-webkit-line-clamp:6;-webkit-box-orient:vertical;">${safeTitle}</div>`;
const catHtml = cat
	? `<div xmlns="http://www.w3.org/1999/xhtml" style="display:flex;align-items:center;justify-content:center;height:100%;"><span style="color:white;font-size:12px;font-weight:600;font-family:system-ui,sans-serif;background:oklch(1 0 0 / 0.15);padding:2px 10px;border-radius:10px;max-width:100%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${cat}</span></div>`
	: "";

const svgHtml = `<svg viewBox="0 0 200 260" xmlns="http://www.w3.org/2000/svg" class="w-full h-full" preserveAspectRatio="xMidYMid slice">
  <defs>
    <linearGradient id="cover-bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:hsl(var(--hue, 250) 50% 65% / 0.5)"/>
      <stop offset="100%" style="stop-color:hsl(var(--hue, 250) 40% 50% / 0.5)"/>
    </linearGradient>
    <pattern id="dots" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
      <circle cx="10" cy="10" r="${dotSize}" fill="white" opacity="0.06"/>
    </pattern>
  </defs>
  <rect width="200" height="260" fill="url(#cover-bg)"/>
  <rect width="200" height="260" fill="url(#dots)"/>
  ${shapesHtml}
  ${cat ? `<foreignObject x="40" y="80" width="120" height="28">${catHtml}</foreignObject>` : ""}
  <foreignObject x="10" y="${cat ? 110 : 70}" width="180" height="${cat ? 100 : 120}">
    <div xmlns="http://www.w3.org/1999/xhtml" style="display:flex;align-items:center;justify-content:center;height:100%;padding:0 4px;box-sizing:border-box;">
      ${titleHtml}
    </div>
  </foreignObject>
</svg>`;
---

{
  hasImage ? (
    <ImageWrapper
      id={id}
      src={image!}
      basePath={basePath}
      class={className || "w-full h-full"}
    />
  ) : (
    <div class={className || "w-full h-full"} id={id} set:html={svgHtml} />
  )
}
</astro>
