---
import PasswordModal from "./PasswordModal.svelte";

export interface Props {
	encryptedContent: string;
	hint?: string;
}

const { encryptedContent, hint = "" } = Astro.props;
---

<div id="password-protection">
	<PasswordModal client:load hint={hint} />
</div>

<div
	id="decrypted-content"
	class="markdown-content mb-6"
	style="display: none;"
></div>

<style>
	.decrypted-content {
		animation: fadeIn 0.3s ease-in-out;
	}
	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}
</style>

<script is:inline define:vars={{ encryptedContent }}>
	async function loadCrypto() {
		if (typeof CryptoJS === "undefined") {
			await new Promise((resolve, reject) => {
				const script = document.createElement("script");
				script.src = "https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.2.0/crypto-js.min.js";
				script.onload = resolve;
				script.onerror = reject;
				document.head.appendChild(script);
			});
		}
	}

	async function attemptUnlock(inputPassword) {
		if (!inputPassword) {
			document.dispatchEvent(new CustomEvent("password:error", { detail: "请输入密码" }));
			return;
		}

		document.dispatchEvent(new CustomEvent("password:loading", { detail: true }));
		document.dispatchEvent(new CustomEvent("password:clear-error", {}));

		await loadCrypto();

		try {
			const decryptedBytes = CryptoJS.AES.decrypt(encryptedContent, inputPassword);
			const decryptedString = decryptedBytes.toString(CryptoJS.enc.Utf8);

			if (!decryptedString || !decryptedString.startsWith("VERIFY:")) {
				document.dispatchEvent(new CustomEvent("password:error", { detail: "密码错误" }));
				sessionStorage.removeItem("page-password-" + window.location.pathname);
				document.dispatchEvent(new CustomEvent("password:loading", { detail: false }));
				return;
			}

			const realContent = decryptedString.replace("VERIFY:", "");
			const contentDiv = document.getElementById("decrypted-content");
			const protectionDiv = document.getElementById("password-protection");

			if (contentDiv) {
				contentDiv.innerHTML = realContent;

				// re-execute scripts
				contentDiv.querySelectorAll("script").forEach((script) => {
					const newScript = document.createElement("script");
					if (script.type) newScript.type = script.type;
					newScript.textContent = script.textContent;
					script.parentNode?.replaceChild(newScript, script);
				});

				if (protectionDiv?.parentNode) {
					protectionDiv.remove();
				}
				contentDiv.style.display = "block";

				sessionStorage.setItem("page-password-" + window.location.pathname, inputPassword);
			}
		} catch (error) {
			console.error("Decryption failed:", error);
			document.dispatchEvent(new CustomEvent("password:error", { detail: "解密失败，请重试" }));
		} finally {
			document.dispatchEvent(new CustomEvent("password:loading", { detail: false }));
		}
	}

	document.addEventListener("password:unlock", async (e) => {
		if (e.detail?.password) {
			await attemptUnlock(e.detail.password);
		}
	});

	// auto-decrypt if password saved in session
	const savedPassword = sessionStorage.getItem("page-password-" + window.location.pathname);
	if (savedPassword) {
		attemptUnlock(savedPassword);
	}
</script>
