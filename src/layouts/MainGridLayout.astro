---
import BackToTop from "@components/control/BackToTop.astro";
import Footer from "@components/Footer.astro";
import Navbar from "@components/Navbar.astro";
import SideBar from "@components/widget/SideBar.astro";
import type { MarkdownHeading } from "astro";
import { Icon } from "astro-icon/components";
import CookieConsent from "../components/CookieConsent.astro";
import ImageWrapper from "../components/misc/ImageWrapper.astro";
import TOC from "../components/widget/TOC.astro";
import SiteStats from "../components/widget/SiteStats.astro";
import { siteConfig } from "../config";
import {
	BANNER_HEIGHT,
	BANNER_HEIGHT_EXTEND,
	MAIN_PANEL_OVERLAPS_BANNER_HEIGHT,
} from "../constants/constants";
import Layout from "./Layout.astro";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	headings?: MarkdownHeading[];
	hideSidebar?: boolean;
	hideRightSidebar?: boolean;
	compact?: boolean;
}

const {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	headings = [],
	hideSidebar,
	hideRightSidebar,
	compact,
} = Astro.props;
const hasBannerCredit =
	siteConfig.banner.enable && siteConfig.banner.credit.enable;
const hasBannerLink = !!siteConfig.banner.credit.url;

const mainPanelTop = compact
	? "5.5rem"
	: siteConfig.banner.enable
		? `calc(${BANNER_HEIGHT}vh - ${MAIN_PANEL_OVERLAPS_BANNER_HEIGHT}rem)`
		: "5.5rem";
---

<Layout title={title} banner={banner} description={description} lang={lang} setOGTypeArticle={setOGTypeArticle}>

<!-- Navbar -->
<slot slot="head" name="head"></slot>
<div id="top-row" class="z-50 pointer-events-none relative transition-all duration-700 max-w-[var(--page-width)] px-0 md:px-4 mx-auto" class:list={[""]}>
    <div id="navbar-wrapper" class="pointer-events-auto sticky top-0 transition-all">
        <Navbar></Navbar>
    </div>
</div>

<!-- Banner -->
{siteConfig.banner.enable && <div id="banner-wrapper" class={`fixed z-10 w-full transition duration-700 overflow-hidden`} style={`top: -${BANNER_HEIGHT_EXTEND}vh`}>
    <ImageWrapper id="banner" alt="Banner image of the blog" class:list={["object-cover h-full transition duration-700 opacity-0 scale-105"]}
                  src={siteConfig.banner.src} position={siteConfig.banner.position}
    >
    </ImageWrapper>
</div>}

<!-- Main content -->
<div class="absolute w-full z-30 pointer-events-none" style={`top: ${mainPanelTop}`}>
    <!-- The pointer-events-none here prevent blocking the click event of the TOC -->
    <div class="relative max-w-[var(--page-width)] mx-auto pointer-events-auto">
        <div id="main-grid" class="transition duration-700 w-full left-0 right-0 grid grid-cols-[17.5rem_auto] grid-rows-[auto_1fr_auto] lg:grid-rows-[auto] 2xl:grid-cols-[17.5rem_1fr_17.5rem]
    mx-auto gap-4 px-0 md:px-4"
        >
            <!-- Banner image credit -->
            {hasBannerCredit && <a href={siteConfig.banner.credit.url} id="banner-credit" target="_blank" rel="noopener" aria-label="Visit image source"
                                   class:list={["group onload-animation transition-all absolute flex justify-center items-center rounded-full " +
                                   "px-3 right-4 -top-[3.25rem] bg-black/60 hover:bg-black/70 h-9", {"hover:pr-9 active:bg-black/80": hasBannerLink}]}
            >
                <Icon class="text-white/75 text-[1.25rem] mr-1" name="material-symbols:copyright-outline-rounded" ></Icon>
                <div class="text-white/75 text-xs">{siteConfig.banner.credit.text}</div>
                <Icon class:list={["transition absolute text-[oklch(0.75_0.14_var(--hue))] right-4 text-[0.75rem] opacity-0",
                    {"group-hover:opacity-100": hasBannerLink}]}
                      name="fa6-solid:arrow-up-right-from-square">
                </Icon>
            </a>}


            {!hideSidebar && <SideBar class="mb-4 row-start-2 row-end-3 col-span-2 lg:row-start-1 lg:row-end-2 lg:col-span-1 lg:max-w-[17.5rem]" headings={headings}></SideBar>}

            <main id="swup-container" class:list={["transition-swup-fade", {"col-span-2 lg:col-span-full": hideSidebar, "col-span-2 lg:col-span-1": !hideSidebar}]}>
                <div id="content-wrapper">
                    <!-- the overflow-hidden here prevent long text break the layout-->
                    <!-- make id different from windows.swup global property -->
                    <slot></slot>
                    <div class="footer col-span-2 onload-animation hidden lg:block">
                        <Footer></Footer>
                    </div>
                </div>
            </main>

            <div class="footer col-span-2 onload-animation block lg:hidden">
                <Footer></Footer>
            </div>

            <!-- Right sidebar: stats + TOC -->
            {!hideRightSidebar && <div id="right-sidebar" class="hidden 2xl:block col-start-3 col-end-4 row-start-1 row-end-2 self-start sticky top-4">
                <div class="mb-4"><SiteStats /></div>
                {siteConfig.toc.enable && <div id="toc-wrapper" class="transition" class:list={[{"toc-hide": siteConfig.banner.enable}]}>
                    <div id="toc-inner-wrapper" class="card-base pb-4">
                        <div class="font-bold transition text-lg text-neutral-900 dark:text-neutral-100 relative ml-8 mt-4 mb-2
                            before:w-1 before:h-4 before:rounded-md before:bg-[var(--primary)]
                            before:absolute before:left-[-16px] before:top-[5.5px]">目录</div>
                        <div data-toc-scroll class="overflow-y-auto" style="max-height: calc(100vh - 30rem); overscroll-behavior: contain; scrollbar-width: thin; scrollbar-color: var(--scrollbar-bg) transparent;">
                            <div id="toc" class="w-full transition-swup-fade px-4">
                                <TOC headings={headings}></TOC>
                            </div>
                        </div>
                    </div>
                </div>}
            </div>}
        </div>

        <BackToTop></BackToTop>
    </div>
</div>

<!-- #toc fallback for Swup -->
{!siteConfig.toc.enable && <div id="toc"></div>}
<CookieConsent />
<script>
	function trackPageview() {
		const path = window.__CANONICAL_SLUG__
			? "/posts/" + window.__CANONICAL_SLUG__ + "/"
			: window.location.pathname;
		fetch("/api/view", {
			method: "POST",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify({ path }),
		}).catch(() => {});
	}

	trackPageview();
	document.addEventListener("swup:contentReplaced", function () {
		setTimeout(trackPageview, 100);
	});
</script>
</Layout>
