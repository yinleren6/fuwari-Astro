---
import { Icon } from "astro-icon/components";
import { siteConfig } from "../config";
import { url, getPostUrlBySlug, getDir } from "../utils/url-utils";
import { getSortedPosts } from "../utils/content-utils";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import ImageWrapper from "../components/misc/ImageWrapper.astro";
import path from "node:path";
import { formatDateToYYYYMMDD } from "../utils/date-utils";

const allPosts = await getSortedPosts();
const recentPosts = allPosts.slice(0, 6);

interface LinkCard {
	name: string;
	description: string;
	url: string;
	icon: string;
}

const links: LinkCard[] = [
	{
		name: "Blog",
		description: "博客文章列表",
		url: "/blog/",
		icon: "material-symbols:article-outline-rounded",
	},
	{
		name: "Game",
		description: "游戏服务器",
		url: "/game/",
		icon: "material-symbols:sports-esports-outline-rounded",
	},
	{
		name: "工具箱",
		description: "我的站点与小工具",
		url: "/tools/",
		icon: "material-symbols:build-outline-rounded",
	},
	/*
	// 在这里添加新的链接按钮，复制上面的结构，修改以下字段：
	// name - 按钮显示的标题
	// description - 按钮下方的描述文字
	// url - 链接地址，内部路由用 "/path/" 格式，外部链接写完整的 URL
	// icon - 图标名称，从 https://icones.js.org/ 找
	{
		name: "你的标题",
		description: "你的描述",
		url: "/your-path/",
		icon: "material-symbols:link-rounded",
	},
	*/
];
---
<MainGridLayout title="" description="" compact={true}>
	<div class="flex flex-col items-center px-4 py-8 gap-8 onload-animation">

		<!-- Quick Links -->
		<div class="flex flex-wrap justify-center gap-3 w-full max-w-xl">
			{links.map((link) => (
				<a
					href={link.external ? link.url : url(link.url)}
					target={link.external ? "_blank" : undefined}
					class="card-base flex items-center gap-3 px-5 py-3 rounded-[var(--radius-large)] min-w-[11rem] flex-1
					       hover:scale-[1.02] active:scale-[0.98] transition-transform"
				>
					<div class="w-9 h-9 rounded-lg bg-[var(--primary)]/10 flex items-center justify-center shrink-0">
						<Icon name={link.icon} class="text-[1.125rem] text-[var(--primary)]" />
					</div>
					<div class="min-w-0">
						<div class="font-bold text-sm flex items-center gap-1">
							{link.name}
							{link.external && <Icon name="fa6-solid:arrow-up-right-from-square" class="text-[0.625rem] opacity-50" />}
						</div>
						<div class="text-xs text-[var(--text-secondary)] truncate">{link.description}</div>
					</div>
				</a>
			))}
		</div>

		<!-- Recent Posts -->
		<div class="w-full max-w-5xl">
			<div class="flex items-center gap-3 mb-5">
				<h2 class="font-bold text-lg text-[var(--primary)]">最近文章</h2>
				<div class="flex-1 h-px bg-[var(--line-divider)]"></div>
				<a href="/blog/" class="text-sm text-[var(--text-secondary)] hover:text-[var(--primary)] transition shrink-0">
					查看全部 →
				</a>
			</div>

			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
				{recentPosts.map((post, i) => (
					<a
						href={getPostUrlBySlug(post.slug)}
						class="card-base group block rounded-[var(--radius-large)] hover:scale-[1.02] active:scale-[0.98] transition-transform"
						style={`animation-delay: calc(var(--content-delay) + ${i * 60}ms);`}
					>
						{post.data.image ? (
							<div class="aspect-[16/9] overflow-hidden">
								<ImageWrapper
									src={post.data.image}
									basePath={path.join("content/posts/", getDir(post.id))}
									alt={post.data.title}
									class="w-full h-full group-hover:scale-105 transition-transform duration-500"
								/>
							</div>
						) : (
							<div class="aspect-[16/9] bg-[var(--primary)]/5 flex items-center justify-center">
								<Icon name="material-symbols:article-outline-rounded" class="text-4xl text-[var(--primary)]/20" />
							</div>
						)}
						<div class="p-4">
							<div class="text-xs text-[var(--text-secondary)] mb-1">{formatDateToYYYYMMDD(post.data.published)}</div>
							<h3 class="font-bold text-sm leading-snug group-hover:text-[var(--primary)] transition line-clamp-2">
								{post.data.title}
							</h3>
						</div>
					</a>
				))}
			</div>
		</div>

	</div>
</MainGridLayout>

<style is:global>
	body.lg\:is-home #sidebar,
	body.lg\:is-home #right-sidebar {
		display: none !important;
	}
	body.lg\:is-home #swup-container {
		grid-column: 1 / -1 !important;
	}
</style>
